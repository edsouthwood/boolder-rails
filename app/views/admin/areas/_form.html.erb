<div class="col-span-6 sm:col-span-4">
  <%= form.label :published %>
  <%= form.check_box :published %>
</div>
<div class="col-span-6 sm:col-span-2"></div>

<div class="col-span-6 sm:col-span-4">
  <%= form.label :name %>
  <%= form.text_field :name, autocomplete: "off" %>
</div>

<div class="col-span-6 sm:col-span-4">
  <%= form.label :short_name %>
  <%= form.text_field :short_name, autocomplete: "off" %>
</div>

<div class="col-span-6 sm:col-span-4">
  <%= form.label :slug %>
  <%= form.text_field :slug, autocomplete: "off" %>
</div>
<div class="col-span-6 sm:col-span-2"></div>

<div class="col-span-6 sm:col-span-2">
  <%= form.label :priority %>
  <%= form.select :priority, [["1", 1], ["2", 2], ["3", 3]] %>
</div>
<div class="col-span-6 sm:col-span-4"></div>

<div class="col-span-6 sm:col-span-4">
  <%= form.label :tags, 'Tags' %>
  <%= form.select :tags,
      options_for_select(
        [['Popular', 'popular'], ['Beginner friendly', 'beginner_friendly'], ['Family friendly', 'family_friendly'], ['Dries fast', 'dry_fast'], ['Sheltered', 'sheltered'], ['Sensitive access', 'sensitive_access'], ['Remote', 'remote']],
        @area.tags
      ),
      { include_blank: false },
      { multiple: true, size: 7 } %>
</div>

<div class="col-span-6 sm:col-span-6">
  <%= form.label :description_en, "Description" %>
  <%= form.text_area :description_en, rows: 5 %>
</div>

<div class="col-span-6 sm:col-span-6">
  <%= form.label :warning_en, "Warning" %>
  <%= form.text_area :warning_en, rows: 3 %>
</div>

<div class="col-span-6 sm:col-span-4">
  <%= image_tag(@area.cover) if @area.cover&.persisted? %>
  <%= form.label :cover %>
  <%= form.file_field :cover %>
</div>

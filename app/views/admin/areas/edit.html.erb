<% add_breadcrumb "Dartmoor", admin_areas_path %>
<% add_breadcrumb "#{@area.name} ##{@area.id}", admin_area_problems_path(area_slug: @area.slug, circuit_id: "first") %>
<% add_breadcrumb "Edit", nil, class: "active" %>

<div class="mt-10 sm:mt-0">
  <div class="md:grid md:grid-cols-4 md:gap-6">
    <div class="mt-5 md:mt-0 md:col-span-2">
      <%= form_with model: [:admin, @area] do |form| %>
        <div class="shadow overflow-hidden sm:rounded-md">
          <div class="px-4 py-5 bg-white sm:p-6">
            <div class="grid grid-cols-6 gap-6">
              <%= render "form", form: form %>
            </div>
          </div>
          <div class="px-4 py-3 bg-gray-50 text-right sm:px-6">
            <button type="submit" class="btn">Update</button>
          </div>
        </div>
      <% end %>

      <% if current_admin_user.super_admin? %>
        <%= button_to "Delete #{@area.name}", admin_area_path(@area), method: :delete, data: { turbo_confirm: "Delete #{@area.name} and all its problems? This cannot be undone." }, class: "mt-4 text-red-600 text-sm underline" %>
      <% end %>
    </div>
    <div class="md:col-span-2">
      <div class="px-4 sm:px-0">
        <ul class="mb-4">
          <% @area.poi_routes.each do |poi_route| %>
            <li><%= link_to poi_route.description, edit_admin_poi_route_path(poi_route) %></li>
          <% end %>
        </ul>
        <%= link_to "New poi route", new_admin_poi_route_path(area_id: @area.id) %>

        <div class="mt-6 border-t pt-4">
          <p class="text-sm text-gray-600 mb-2">
            <strong>Request photos</strong> — creates open contribution requests for all
            problems that have a location but no topo photo, skipping any that already
            have an open request.
          </p>
          <% needs_photos = @area.problems.with_location.without_line.count %>
          <p class="text-xs text-gray-400 mb-3">
            <%= needs_photos %> problem<%= "s" if needs_photos != 1 %> currently without a photo.
          </p>
          <%= button_to "Request photos (#{needs_photos})",
                admin_area_request_photos_path(area_slug: @area.slug),
                method: :post,
                data: { turbo_confirm: "Create photo contribution requests for #{needs_photos} problem#{"s" if needs_photos != 1}?" },
                class: "btn",
                disabled: needs_photos.zero? %>
        </div>
      </div>
    </div>
  </div>
</div>

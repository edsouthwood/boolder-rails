<h1 class="my-3">Bulk upload problems</h1>

<% if flash[:error] %>
  <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded text-red-700 text-sm space-y-1">
    <% flash[:error].split(" | ").each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div class="mt-6 max-w-2xl">
  <div class="bg-white shadow sm:rounded-md overflow-hidden">
    <%= form_with url: admin_bulk_uploads_path, multipart: true do |form| %>
      <div class="px-4 py-5 sm:p-6 space-y-6">

        <div>
          <%= form.label :area_id, "Area", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.collection_select :area_id, @areas, :id, :name,
                { include_blank: "Select an area" },
                { class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm" } %>
        </div>

        <div>
          <%= form.label :csv_file, "CSV file", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.file_field :csv_file, accept: ".csv", class: "mt-1 block w-full text-sm text-gray-500" %>
          <p class="mt-2 text-xs text-gray-400">
            Required columns: <code>steepness</code>. Optional: <code>name, grade, sit_start, lat, lon, image_filename, ukc_url</code>
          </p>
        </div>

        <div>
          <%= form.label :images, "Images", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.file_field :images, multiple: true, accept: "image/*", class: "mt-1 block w-full text-sm text-gray-500" %>
          <p class="mt-2 text-xs text-gray-400">
            Upload all images referenced in the CSV <code>image_filename</code> column. Filenames must match exactly.
          </p>
        </div>

        <div class="bg-gray-50 rounded p-4 text-xs text-gray-500 space-y-2">
          <p class="font-medium text-gray-600">Example CSV</p>
          <pre class="overflow-x-auto">name,grade,steepness,sit_start,lat,lon,image_filename,ukc_url
Overhanging Scoop,5c,overhang,false,50.5712,-3.9341,overhanging_scoop.jpg,
Low Traverse,4a,traverse,false,50.5715,-3.9345,low_traverse.jpg,
Unnamed Slab,,slab,false,,,</pre>
          <p>Valid steepness values: <%= Problem::STEEPNESS_VALUES.join(", ") %></p>
          <p>Images are attached as topos without line coordinates — draw lines manually in the topo editor afterwards.</p>
        </div>

      </div>

      <div class="px-4 py-3 bg-gray-50 text-right sm:px-6">
        <%= form.submit "Upload", class: "btn" %>
      </div>
    <% end %>
  </div>
</div>

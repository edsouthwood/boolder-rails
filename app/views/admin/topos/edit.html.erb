<% add_breadcrumb "Dartmoor", admin_areas_path %>
<% if area = @topo.problems.first&.area %>
  <% add_breadcrumb area.name, admin_area_problems_path(area_slug: area.slug, circuit_id: "first") %>
<% end %>
<% add_breadcrumb "Topo ##{@topo.id}", nil, class: "active" %>

<div class="my-3">
  <% @topo.problems.each do |problem| %>
    <span class="mr-3">
      <%= problem_circle_view_with_name(problem) %>
    </span>
  <% end %>
</div>

<div>
  <div>
    <%= image_tag(@topo.photo) %>
  </div>

  <%= form_with model: [:admin, @topo] do |form| %>
    <div class="form-group form-check mt-8">
      <%= form.check_box :published, class: "form-check-input" %>
      <%= form.label :published %>
    </div>

    <div class="form-group">
      <p class="my-8">
        <div>Metadata</div>
        <code>
          <pre>
            <%= JSON.pretty_generate(@topo.metadata) %>
          </pre>
        </code>
      </p>

      <div class="mt-8">
        <%= form.submit("Update", class: "btn btn-primary") %>
      </div>
    </div>
  <% end %>

  <div class="mt-4">
    <%= button_to "Delete topo", admin_topo_path(@topo),
          method: :delete,
          data: { turbo_confirm: "Delete this topo and all its lines? This cannot be undone." },
          class: "px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-medium rounded transition-colors" %>
  </div>
</div>

<div style="margin-bottom: 300px"></div>

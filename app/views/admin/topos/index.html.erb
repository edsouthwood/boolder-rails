<% add_breadcrumb "Dartmoor", admin_areas_path %>
<% add_breadcrumb @area.name, admin_area_problems_path(area_slug: @area.slug, circuit_id: "first") %>
<% add_breadcrumb "Topos", nil, class: "active" %>

<p class="text-sm text-gray-500 my-4"><%= pluralize(@topos.size, "topo") %></p>

<% if @topos.any? %>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
    <% @topos.each do |topo| %>
      <div class="border border-gray-200 rounded overflow-hidden bg-white shadow-sm">
        <%= link_to edit_admin_topo_path(topo) do %>
          <%= cdn_image_tag topo.photo.variant(:thumb), class: "w-full h-36 object-cover block" %>
        <% end %>
        <div class="p-2">
          <p class="text-xs font-medium text-gray-500 mb-1">Topo #<%= topo.id %></p>
          <% topo.problems.each do |problem| %>
            <div class="flex items-center gap-1 mb-1">
              <%= problem_circle_view(problem) %>
              <%= link_to problem.name_with_fallback, admin_problem_path(problem),
                    class: "text-xs text-gray-700 hover:underline truncate" %>
            </div>
          <% end %>
          <div class="mt-2">
            <%= button_to "Delete", admin_topo_path(topo),
                  method: :delete,
                  data: { turbo_confirm: "Delete topo ##{topo.id} and all its lines? This cannot be undone." },
                  class: "text-xs text-red-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-gray-400 italic">No topos found for this area.</p>
<% end %>

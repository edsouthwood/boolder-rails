<% set_meta_tags title: "About Boolder Dartmoor" %>

<% set_meta_tags og: { type: "website", image: image_url("hero-about.jpg") } %>

<main class="lg:relative bg-white">
  <div class="mx-auto w-full max-w-7xl pt-16 pb-20 text-center lg:py-48 lg:text-left">
    <div class="px-6 sm:px-8 lg:w-1/2 xl:pr-16">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl md:text-6xl lg:text-5xl xl:text-6xl">
        <span class="block xl:inline">About</span>
        <span class="block text-emerald-600 xl:inline">Boolder Dartmoor</span>
      </h1>
    </div>
  </div>
  <div class="relative h-64 w-full sm:h-72 md:h-96 lg:absolute lg:inset-y-0 lg:right-0 lg:h-full lg:w-1/2">
    <img class="absolute inset-0 h-full w-full object-cover" src="<%= image_path "hero-about.jpg" %>" alt="">
  </div>
</main>

<div class="bg-warm-gray-50 mt-4 sm:mt-16">

  <section>
    <div class="mx-auto max-w-7xl py-8 px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-warm-gray-900">
        The Project
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        Boolder Dartmoor is a free, open-source bouldering guide for Dartmoor, bringing the best of the Boolder platform to one of the UK's finest outdoor bouldering destinations.
      </p>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        Ed Southwood and the team are leading this project, mapping Dartmoor's bouldering areas and building a community resource that is free for everyone to use and enjoy.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-7xl py-8 px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-warm-gray-900">
        Thank you, Boolder
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        This project stands on the shoulders of the original Boolder team — Nicolas, Romain, Cyril, Émile, and Gaël — who built something truly special for the Fontainebleau climbing community.
      </p>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        Their dedication in mapping thousands of problems, building a beautiful open-source platform, and making it freely available to the world has made projects like this one possible. We are hugely grateful for their work and generosity.
      </p>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-7xl py-8 px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-warm-gray-900">
        A collaborative platform
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        The code and data for this project are available in open source on <%= link_to "GitHub", "https://github.com/boolder-org", class: "font-medium underline text-emerald-600" %>.
      </p>
      <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
        You can also <%= link_to "contribute", contribute_path, class: "font-medium underline text-emerald-600" %> by mapping missing problems or reporting mistakes.
      </p>
    </div>
  </section>

  <div class="bg-warm-gray-50">
    <section id="contact">
      <div class="mx-auto max-w-7xl py-8 px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-warm-gray-900">
          Contact
        </h2>
        <p class="mt-6 max-w-3xl text-lg text-warm-gray-500">
          For questions about the Dartmoor guide, you can contact us at <%= link_to "hello@boolder.com", "mailto:hello@boolder.com", class: "font-medium underline text-emerald-600" %>.
        </p>
        <p class="mt-4 max-w-3xl text-lg text-warm-gray-500">
          Please note that <%= link_to "hello@boolder.com", "mailto:hello@boolder.com", class: "font-medium underline text-emerald-600" %> is also the contact address for the original French Boolder team. If your question is specifically about Fontainebleau, they are the right people to reach.
        </p>
      </div>
    </section>

    <section>
      <div class="mx-auto max-w-7xl py-8 px-6 lg:px-8">
        <h2 class="text-3xl font-bold tracking-tight text-warm-gray-900">
          Frequently asked questions
        </h2>
        <dl class="space-y-10 my-8">
          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">
              Where does the data come from?
            </dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">
              Photos and geographical data (GPS) are collected on the ground by the Dartmoor team.
            </dd>
          </div>

          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">
              Why is this free?
            </dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">
              Because we want as many people as possible to discover and enjoy Dartmoor's bouldering. This is a volunteer-run, non-profit project.
            </dd>
          </div>

          <div>
            <dt class="text-base font-semibold leading-7 text-gray-900">
              Do you collect personal data?
            </dt>
            <dd class="mt-2 text-base leading-7 text-gray-600">
              <%= link_to "Privacy policy", privacy_path, class: "font-medium underline text-emerald-600" %>
            </dd>
          </div>
        </dl>
      </div>
    </section>
  </div>

</div>

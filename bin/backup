#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
LOG="$SCRIPT_DIR/log/backup.log"
ENV_FILE="$SCRIPT_DIR/.env.backup"
DB_NAME="dartmoor-dev"
STORAGE_DIR="$SCRIPT_DIR/storage"
MASTER_KEY="$SCRIPT_DIR/config/master.key"
KEEP_DUMPS=7

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG"; }

if [[ ! -f "$ENV_FILE" ]]; then
  log "ERROR: $ENV_FILE not found — create it with BACKUP_REMOTE=user@host:/path"
  exit 1
fi

source "$ENV_FILE"

if [[ -z "${BACKUP_REMOTE:-}" ]]; then
  log "ERROR: BACKUP_REMOTE is not set in $ENV_FILE"
  exit 1
fi

BACKUP_HOST="${BACKUP_REMOTE%%:*}"
BACKUP_PATH="${BACKUP_REMOTE#*:}"
DATESTAMP="$(date '+%Y%m%d')"
TMPDIR="$(mktemp -d)"
trap 'rm -rf "$TMPDIR"' EXIT

log "Starting backup to $BACKUP_REMOTE"

# Ensure remote directories exist
ssh "$BACKUP_HOST" "mkdir -p '${BACKUP_PATH}/db' '${BACKUP_PATH}/storage'"

# 1. Database dump
DUMP_FILE="$TMPDIR/${DB_NAME}-${DATESTAMP}.sql.gz"
log "Dumping $DB_NAME..."
pg_dump "$DB_NAME" | gzip > "$DUMP_FILE"
log "Dump complete: $(du -sh "$DUMP_FILE" | cut -f1)"

# 2. Upload database dump
log "Uploading database dump..."
rsync -az "$DUMP_FILE" "${BACKUP_REMOTE}/db/"

# 3. Prune old database dumps (keep last KEEP_DUMPS)
log "Pruning old dumps (keeping $KEEP_DUMPS)..."
ssh "$BACKUP_HOST" "cd '${BACKUP_PATH}/db' && ls -t *.sql.gz 2>/dev/null | tail -n +$((KEEP_DUMPS + 1)) | xargs -r rm -f"

# 4. Sync storage files incrementally
log "Syncing storage files..."
rsync -az --delete "$STORAGE_DIR/" "${BACKUP_REMOTE}/storage/"
log "Storage sync complete"

# 5. Backup master key (once, idempotent)
if [[ -f "$MASTER_KEY" ]]; then
  log "Backing up master.key..."
  rsync -az "$MASTER_KEY" "${BACKUP_REMOTE}/master.key"
fi

log "Backup complete"
